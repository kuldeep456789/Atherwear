# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/aetherwear

# Server Configuration
PORT=3000
NODE_ENV=production

# CJ Dropshipping API
CJ_API_BASE_URL=https://developers.cjdropshipping.com/api2.0
CJ_API_KEY=your_cj_api_key
CJ_EMAIL=your_cj_email@domain.com
CJ_MOCK_MODE=false

# Redis Cache
REDIS_URL=redis://localhost:16379
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=16379
REDIS_PASSWORD=

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Twilio SMS Verification
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_VERIFY_SERVICE_SID=your_twilio_verify_service_sid

# Resend Email Service
RESEND_API_KEY=your_resend_api_key
FROM_EMAIL=VASTRA <onboarding@resend.dev>
ADMIN_EMAIL=your_admin_email@domain.com

# Admin Secret Registration Code
ADMIN_SECRET_CODE=your_admin_secret_code
